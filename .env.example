# Template d'environnement pour Suivi Projets Mairie
# Copier en .env.local (dev) ou .env (prod) puis remplir les valeurs.
# NE JAMAIS COMMITTER LES FICHIERS REMPLIS.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=changemoi-en-prod-via-openssl-rand-hex-32
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# En dev (docker compose), le hostname "postgres" est résolu par le réseau interne
DATABASE_URL="postgresql://spm:spm@postgres:5432/spm?serverVersion=16&charset=utf8"
POSTGRES_DB=spm
POSTGRES_USER=spm
POSTGRES_PASSWORD=spm
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

###> mailer ###
# En dev, on capture les mails dans Mailpit
MAILER_DSN=smtp://mailpit:1025
# En prod : smtp://user:pass@smtp.example.fr:587
###< mailer ###

###> messenger ###
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
###< messenger ###

###> drenso/symfony-oidc-bundle ###
# URL well-known du provider OIDC (Authentik expose ce endpoint à
# <issuer>/.well-known/openid-configuration). drenso lit toute la config
# (authorization endpoint, token endpoint, jwks_uri, etc.) à partir de cette URL.
OIDC_WELL_KNOWN_URL=https://authentik.mairie.example.fr/application/o/suivi-projets-mairie/.well-known/openid-configuration

# Identifiants du provider OIDC créé dans Authentik (cf. docs/authentik.md §1.1)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# URL de callback (doit correspondre EXACTEMENT à ce qui est dans Authentik)
# En dev local, l'app écoute en HTTPS sur https://spm.localhost (cf. docs/local-dev.md §3)
OIDC_REDIRECT_URI=https://spm.localhost/oidc/callback

# Scopes demandés au token
OIDC_SCOPES="openid email profile groups"

# Groupe Authentik des admins applicatifs.
# Tout utilisateur membre de ce groupe se voit attribuer ROLE_ADMIN au login.
# C'est le seul rôle "statique" — les autres (CHEF_PROJET, ACTEUR, LECTEUR)
# sont calculés dynamiquement par les voters selon l'objet (cf. specs §2).
OIDC_ADMIN_GROUP="admin_spm"

# Filtrage d'accès à l'application (defense in depth)
# L'utilisateur doit appartenir à au moins un de ces groupes Authentik pour pouvoir
# se connecter, en complément de la Policy Binding configurée côté Authentik.
# Typiquement : un méga-groupe parent qui contient admin_spm + tous les groupes
# de travail de la mairie utilisés par l'app.
# Voir docs/authentik.md §1.5.
OIDC_REQUIRED_GROUPS="spm_users"
###< drenso/symfony-oidc-bundle ###

###> reverse proxy (prod) ###
# Plages d'IP des reverse proxies de confiance pour le décodage de X-Forwarded-*
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^(localhost|spm\.localhost|projets\.mairie\.example\.fr)$'
###< reverse proxy ###

###> dev local (FrankenPHP / Caddy) ###
# Nom de domaine local servi par FrankenPHP en HTTPS.
# Par défaut spm.localhost (résolu auto vers 127.0.0.1, RFC 6761).
# Voir docs/local-dev.md §3 pour le TLS local.
DEV_SERVER_NAME=spm.localhost
###< dev local ###

###> sentry/sentry-symfony ###
# DSN du projet Sentry (vide en dev par défaut, renseigné en staging/prod)
# Voir docs/qualite.md §10 pour la configuration recommandée.
SENTRY_DSN=

# Environnement courant tel qu'affiché dans Sentry.
# Valeurs typiques : "dev", "staging", "production".
# Distinct de APP_ENV (qui contrôle Symfony) pour pouvoir avoir plusieurs
# environnements applicatifs prod différenciés côté Sentry.
SENTRY_ENV=dev

# Version applicative déployée — sert de "release" Sentry pour mapper les erreurs
# au tag git correspondant (cf. docs/deploiement.md). Laissé vide en dev.
APP_VERSION=
###< sentry/sentry-symfony ###

###> dev only ###
# Active Xdebug en mode debug (laisser vide pour désactiver)
XDEBUG_MODE=
XDEBUG_CLIENT_HOST=host.docker.internal
###< dev only ###
