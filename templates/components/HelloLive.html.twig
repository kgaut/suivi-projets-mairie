<div {{ attributes }} class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <p class="text-sm font-medium text-slate-600">Compteur Live Component</p>
    <p class="mt-2 text-4xl font-bold text-indigo-600">{{ count }}</p>
    <div class="mt-4 flex gap-2">
        <button
            type="button"
            data-action="live#action"
            data-live-action-param="increment"
            class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500"
        >
            +1
        </button>
        <button
            type="button"
            data-action="live#action"
            data-live-action-param="reset"
            class="rounded-md bg-slate-200 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-300"
        >
            Reset
        </button>
    </div>
    <p class="mt-3 text-xs text-slate-500">
        Chaque clic est traité côté serveur (Symfony UX Live Component) — pas de JS applicatif.
    </p>
</div>
