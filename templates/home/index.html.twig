{% extends 'base.html.twig' %}

{% block title %}Hello SPM — Suivi Projets Mairie{% endblock %}

{% block body %}
    <main class="mx-auto max-w-2xl px-4 py-12">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900">Hello SPM</h1>
        <p class="mt-2 text-slate-600">
            Suivi Projets Mairie — squelette Symfony 7.4 LTS opérationnel,
            avec Tailwind CSS, Symfony UX Turbo, Stimulus et Live Components.
        </p>

        <section class="mt-10 grid gap-6 sm:grid-cols-2">
            <div
                class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm"
                data-controller="hello"
            >
                <p class="text-sm font-medium text-slate-600">Démo Stimulus</p>
                <p
                    class="mt-2 text-2xl font-semibold text-slate-900"
                    data-hello-target="output"
                ></p>
                <button
                    type="button"
                    data-action="click->hello#toggle"
                    class="mt-4 rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500"
                >
                    Toggle (côté client)
                </button>
                <p class="mt-3 text-xs text-slate-500">
                    Pure JS via Stimulus — pas de requête serveur.
                </p>
            </div>

            <twig:HelloLive />
        </section>

        <p class="mt-10 text-xs text-slate-500">
            Liens rapides :
            <a href="https://spm.localhost" class="text-indigo-600 hover:underline">app</a> ·
            <a href="http://localhost:8025" class="text-indigo-600 hover:underline">Mailpit</a>
        </p>
    </main>
{% endblock %}
