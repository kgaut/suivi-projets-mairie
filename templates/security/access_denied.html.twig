{% extends 'base.html.twig' %}

{% block title %}Accès non autorisé — Suivi Projets Mairie{% endblock %}

{% block body %}
    <div class="mx-auto max-w-2xl px-4 py-12 text-center">
        <div class="mx-auto mb-6 grid h-16 w-16 place-items-center rounded-full bg-red-100" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-8 w-8 text-red-600">
                <path fill-rule="evenodd" d="M12 1.5a.75.75 0 0 1 .75.75V4.5a.75.75 0 0 1-1.5 0V2.25A.75.75 0 0 1 12 1.5ZM5.636 4.136a.75.75 0 0 1 1.06 0l1.592 1.591a.75.75 0 0 1-1.061 1.06l-1.591-1.59a.75.75 0 0 1 0-1.061Zm12.728 0a.75.75 0 0 1 0 1.06l-1.591 1.592a.75.75 0 0 1-1.06-1.061l1.59-1.591a.75.75 0 0 1 1.061 0Zm-6.816 4.496a.75.75 0 0 1 .82.311l5.228 7.917a.75.75 0 0 1-.777 1.148l-2.097-.43 1.045 3.9a.75.75 0 0 1-1.45.388l-1.044-3.899-1.601 1.42a.75.75 0 0 1-1.247-.606l.569-9.47a.75.75 0 0 1 .554-.679ZM3 10.5a.75.75 0 0 1 .75-.75H6a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 10.5Zm14.25 0a.75.75 0 0 1 .75-.75h2.25a.75.75 0 0 1 0 1.5H18a.75.75 0 0 1-.75-.75Zm-8.962 3.712a.75.75 0 0 1 0 1.061l-1.591 1.591a.75.75 0 1 1-1.061-1.06l1.591-1.592a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
            </svg>
        </div>

        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Accès non autorisé</h1>

        {% if message %}
            <p class="mt-3 text-slate-600">{{ message }}</p>
        {% else %}
            <p class="mt-3 text-slate-600">
                Cette application est réservée aux membres autorisés.
            </p>
        {% endif %}

        <p class="mt-2 text-sm text-slate-500">
            Si vous pensez qu'il s'agit d'une erreur, contactez l'administrateur de l'application.
        </p>

        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
            <a
                href="{{ path('app_logout') }}"
                class="inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700"
            >
                Se déconnecter
            </a>
        </div>
    </div>
{% endblock %}
