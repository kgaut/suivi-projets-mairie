{% extends 'base.html.twig' %}

{% block title %}Accès non autorisé — Suivi Projets Mairie{% endblock %}

{% block body %}
    <div class="mx-auto max-w-2xl px-4 py-12 text-center">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Accès non autorisé</h1>
        <p class="mt-3 text-slate-600">
            Cette application est réservée aux membres autorisés.
            Si vous pensez qu'il s'agit d'une erreur, contactez l'administrateur.
        </p>
        <a
            href="{{ path('app_logout') }}"
            class="mt-6 inline-flex items-center rounded-md bg-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-300"
        >
            Se déconnecter
        </a>
    </div>
{% endblock %}
