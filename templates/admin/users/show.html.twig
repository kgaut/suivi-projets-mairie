{% extends 'admin/_layout.html.twig' %}

{% block admin_title %}{{ user.displayName }}{% endblock %}

{% block admin_breadcrumb %}
    <a href="{{ path('admin_dashboard') }}" class="hover:underline">Administration</a>
    <span aria-hidden="true">›</span>
    <a href="{{ path('admin_users_index') }}" class="hover:underline">Utilisateurs</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">{{ user.displayName }}</span>
{% endblock %}

{% block admin_body %}
    <header class="flex flex-wrap items-center gap-4 border-b border-slate-200 pb-6">
        {{ user|avatar(96) }}
        <div class="min-w-0 flex-1">
            <h1 class="text-2xl font-bold text-slate-900">{{ user.displayName }}</h1>
            <p class="text-sm text-slate-600">{{ user.email }}</p>
            <p class="text-xs text-slate-500">@{{ user.username }}</p>
        </div>
        {% if authentik_url %}
            <a
                href="{{ authentik_url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50"
            >
                Ouvrir dans Authentik ↗
            </a>
        {% endif %}
    </header>

    <section class="mt-6 grid gap-6 sm:grid-cols-2">
        <div class="rounded-lg border border-slate-200 bg-white p-5">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Identifiants</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-2">
                    <dt class="text-slate-600">Identifiant Authentik</dt>
                    <dd class="font-mono text-xs text-slate-900">{{ user.authentikId }}</dd>
                </div>
                <div class="flex justify-between gap-2">
                    <dt class="text-slate-600">UUID interne</dt>
                    <dd class="font-mono text-xs text-slate-900">{{ user.id }}</dd>
                </div>
                <div class="flex justify-between gap-2">
                    <dt class="text-slate-600">Créé le</dt>
                    <dd class="text-slate-900">{{ user.createdAt|date('d/m/Y H:i') }}</dd>
                </div>
                <div class="flex justify-between gap-2">
                    <dt class="text-slate-600">Dernière connexion</dt>
                    <dd class="text-slate-900">
                        {{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y H:i') : 'Jamais' }}
                    </dd>
                </div>
                <div class="flex justify-between gap-2">
                    <dt class="text-slate-600">Statut</dt>
                    <dd>
                        {% if user.disabled %}
                            <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">
                                Désactivé le {{ user.disabledAt|date('d/m/Y') }}
                            </span>
                        {% else %}
                            <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Actif</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>

        <div class="rounded-lg border border-slate-200 bg-white p-5">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Rôles & groupes</h2>
            <dl class="mt-3 space-y-3 text-sm">
                <div>
                    <dt class="text-slate-600">Rôles applicatifs</dt>
                    <dd class="mt-1 flex flex-wrap gap-1">
                        {% for role in user.roles %}
                            <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">{{ role }}</span>
                        {% endfor %}
                    </dd>
                </div>
                <div>
                    <dt class="text-slate-600">Groupes Authentik (snapshot)</dt>
                    <dd class="mt-1">
                        {% if user.groupsSnapshot is empty %}
                            <span class="text-xs text-slate-500">Aucun groupe</span>
                        {% else %}
                            <div class="flex flex-wrap gap-1">
                                {% for group in user.groupsSnapshot %}
                                    <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs text-indigo-700">{{ group }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>
    </section>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Activité</h2>
        <p class="mt-3 text-sm text-slate-600">
            L'historique des contributions (projets créés, tâches assignées, commentaires…) sera affiché ici à partir du Lot 1.
        </p>
    </section>
{% endblock %}
