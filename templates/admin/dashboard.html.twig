{% extends 'admin/_layout.html.twig' %}

{% block admin_title %}Tableau de bord{% endblock %}

{% block admin_body %}
    <h1 class="text-2xl font-bold text-slate-900">Tableau de bord</h1>
    <p class="mt-1 text-sm text-slate-600">Vue d'ensemble de la projection Authentik et des outils internes configurés.</p>

    <dl class="mt-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-lg border border-slate-200 bg-white p-5">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Utilisateurs</dt>
            <dd class="mt-2 flex items-baseline gap-2">
                <span class="text-3xl font-semibold text-slate-900">{{ user_count }}</span>
                <span class="text-sm text-slate-500">dont {{ active_user_count }} actifs</span>
            </dd>
            <a href="{{ path('admin_users_index') }}" class="mt-3 inline-block text-sm font-medium text-indigo-700 hover:underline">Voir la liste →</a>
        </div>

        <div class="rounded-lg border border-slate-200 bg-white p-5">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Liens externes</dt>
            <dd class="mt-2 text-3xl font-semibold text-slate-900">{{ external_link_count }}</dd>
            <a href="{{ path('admin_external_links_index') }}" class="mt-3 inline-block text-sm font-medium text-indigo-700 hover:underline">Gérer les liens →</a>
        </div>

        <div class="rounded-lg border border-slate-200 bg-white p-5">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Référence</dt>
            <dd class="mt-2 text-sm text-slate-700">
                <p>Les utilisateurs sont la projection locale des comptes Authentik. Pour les éditer, passer par Authentik.</p>
            </dd>
        </div>
    </dl>
{% endblock %}
