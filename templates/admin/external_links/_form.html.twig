{# Partial du formulaire ExternalLink, utilisé par new + edit. #}
{{ form_start(form, {attr: {class: 'space-y-4'}}) }}
    <div>
        {{ form_label(form.label, null, {label_attr: {class: 'block text-sm text-slate-700'}}) }}
        {{ form_widget(form.label, {attr: {class: 'mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm'}}) }}
        {{ form_errors(form.label, {attr: {class: 'mt-1 text-xs text-red-700'}}) }}
    </div>

    <div>
        {{ form_label(form.url, null, {label_attr: {class: 'block text-sm text-slate-700'}}) }}
        {{ form_widget(form.url, {attr: {class: 'mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm'}}) }}
        {{ form_errors(form.url, {attr: {class: 'mt-1 text-xs text-red-700'}}) }}
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
        <div>
            {{ form_label(form.icon, null, {label_attr: {class: 'block text-sm text-slate-700'}}) }}
            {{ form_widget(form.icon, {attr: {class: 'mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm'}}) }}
            {{ form_errors(form.icon, {attr: {class: 'mt-1 text-xs text-red-700'}}) }}
        </div>

        <div>
            {{ form_label(form.position, null, {label_attr: {class: 'block text-sm text-slate-700'}}) }}
            {{ form_widget(form.position, {attr: {class: 'mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm'}}) }}
            {{ form_errors(form.position, {attr: {class: 'mt-1 text-xs text-red-700'}}) }}
        </div>
    </div>

    <div>
        {{ form_label(form.description, null, {label_attr: {class: 'block text-sm text-slate-700'}}) }}
        {{ form_widget(form.description, {attr: {class: 'mt-1 w-full rounded-md border border-slate-300 px-2 py-1.5 text-sm'}}) }}
        {{ form_errors(form.description, {attr: {class: 'mt-1 text-xs text-red-700'}}) }}
    </div>

    <label class="inline-flex items-center gap-2 text-sm text-slate-700">
        {{ form_widget(form.enabled) }}
        {{ form_label(form.enabled, null, {label_attr: {class: 'inline'}}) }}
    </label>

    <div class="flex items-center gap-2 pt-2">
        <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500">
            {{ submit_label }}
        </button>
        <a href="{{ path('admin_external_links_index') }}" class="rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">
            Annuler
        </a>
    </div>
{{ form_end(form) }}
