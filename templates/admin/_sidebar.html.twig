{# Sidebar admin. La route courante détermine l'item actif via app.request.attributes.get('_route'). #}
{% set current_route = app.request is not null ? app.request.attributes.get('_route') : null %}
{% set items = [
    {route: 'admin_dashboard', label: 'Tableau de bord', match: 'admin_dashboard'},
    {route: 'admin_users_index', label: 'Utilisateurs', match: 'admin_users'},
    {route: 'admin_external_links_index', label: 'Liens externes', match: 'admin_external_links'},
] %}

<nav aria-label="Navigation administration" class="rounded-lg border border-slate-200 bg-white p-2">
    <ul class="flex flex-col gap-1">
        {% for item in items %}
            {% set active = current_route is same as item.route or (current_route is not null and current_route starts with item.match) %}
            <li>
                <a
                    href="{{ path(item.route) }}"
                    class="block rounded-md px-3 py-2 text-sm {{ active ? 'bg-indigo-50 font-medium text-indigo-700' : 'text-slate-700 hover:bg-slate-50' }}"
                    {% if active %}aria-current="page"{% endif %}
                >
                    {{ item.label }}
                </a>
            </li>
        {% endfor %}
    </ul>
</nav>
