<header class="border-b border-slate-200 bg-white">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
        <a href="{{ path('home') }}" class="flex items-center gap-2 font-semibold tracking-tight text-slate-900">
            <span aria-hidden="true" class="grid h-8 w-8 place-items-center rounded-md bg-indigo-600 text-white">SPM</span>
            <span class="hidden sm:inline">Suivi Projets Mairie</span>
        </a>

        {# Burger CSS-only via checkbox cachée. Activée < 1024 px (lg breakpoint Tailwind). #}
        <input
            type="checkbox"
            id="burger-toggle"
            class="peer sr-only"
            aria-controls="primary-nav"
        >
        <label
            for="burger-toggle"
            class="grid h-10 w-10 cursor-pointer place-items-center rounded-md border border-slate-200 lg:hidden"
            aria-label="Ouvrir le menu"
        >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm.75 4.5a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H2.75Z" clip-rule="evenodd" />
            </svg>
        </label>

        {#
          Nav principale.
          - Mobile (< lg) : panneau plein écran qui s'ouvre via la checkbox burger (peer-checked:flex)
          - Desktop (≥ lg) : nav horizontale toujours visible
        #}
        <nav
            id="primary-nav"
            aria-label="Navigation principale"
            class="
                fixed inset-0 top-[57px] z-40 hidden flex-col gap-2 bg-white px-4 py-4 shadow-lg
                peer-checked:flex
                lg:static lg:flex lg:flex-row lg:items-center lg:gap-4 lg:bg-transparent lg:p-0 lg:shadow-none
            "
        >
            {{ include('_partials/_nav.html.twig') }}

            <div class="mt-auto flex items-center gap-3 border-t border-slate-200 pt-4 lg:ml-auto lg:mt-0 lg:border-0 lg:pt-0">
                {{ include('_partials/_user_menu.html.twig') }}
            </div>
        </nav>
    </div>
</header>
