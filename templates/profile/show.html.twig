{% extends 'base.html.twig' %}

{% block title %}Mon profil — Suivi Projets Mairie{% endblock %}

{% block body %}
    <div class="mx-auto max-w-3xl px-4 py-10">
        {% for flash in app.flashes(['success', 'error']) %}
            {% set color = loop.index0 == 0 ? 'green' : 'red' %}
            <div class="mb-4 rounded-md bg-{{ color }}-50 p-3 text-sm text-{{ color }}-800">{{ flash }}</div>
        {% endfor %}

        <header class="flex items-center gap-4 border-b border-slate-200 pb-6">
            {{ user|avatar(96) }}
            <div>
                <h1 class="text-2xl font-bold text-slate-900">{{ user.displayName }}</h1>
                <p class="text-sm text-slate-600">{{ user.email }}</p>
                <p class="text-xs text-slate-500">@{{ user.username }}</p>
            </div>
        </header>

        <section class="mt-6 grid gap-6 sm:grid-cols-2">
            <div class="rounded-lg border border-slate-200 bg-white p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Identifiants</h2>
                <dl class="mt-3 space-y-2 text-sm">
                    <div class="flex justify-between gap-2">
                        <dt class="text-slate-600">Identifiant Authentik</dt>
                        <dd class="font-mono text-xs text-slate-900">{{ user.authentikId }}</dd>
                    </div>
                    <div class="flex justify-between gap-2">
                        <dt class="text-slate-600">Dernier login</dt>
                        <dd class="text-slate-900">
                            {{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y H:i') : '—' }}
                        </dd>
                    </div>
                    <div class="flex justify-between gap-2">
                        <dt class="text-slate-600">Rôles applicatifs</dt>
                        <dd class="text-slate-900">{{ user.roles|join(', ') }}</dd>
                    </div>
                </dl>
            </div>

            <div class="rounded-lg border border-slate-200 bg-white p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Groupes Authentik</h2>
                {% if user.groupsSnapshot is empty %}
                    <p class="mt-3 text-sm text-slate-500">Aucun groupe.</p>
                {% else %}
                    <ul class="mt-3 flex flex-wrap gap-2">
                        {% for group in user.groupsSnapshot %}
                            <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">{{ group }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
                <p class="mt-4 text-xs text-slate-500">
                    Pour modifier vos infos, rendez-vous sur Authentik
                    (l'application Suivi Projets Mairie ne fait que refléter ce qui s'y trouve).
                </p>
            </div>
        </section>

        <section class="mt-8 rounded-lg border border-slate-200 bg-white p-5">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Avatar</h2>

            <form action="{{ path('app_profile_avatar_upload') }}" method="post" enctype="multipart/form-data" class="mt-4 flex flex-wrap items-center gap-3">
                <label class="text-sm">
                    <span class="block text-slate-700">Uploader une image (jpg/png/webp, max 2 Mo)</span>
                    <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp" required class="mt-1 text-sm">
                </label>
                <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500">
                    Mettre à jour
                </button>
            </form>

            {% if user.avatarPath %}
                <form action="{{ path('app_profile_avatar_delete') }}" method="post" class="mt-3">
                    <button type="submit" class="text-xs text-red-700 hover:underline">
                        Supprimer mon avatar uploadé
                    </button>
                </form>
            {% endif %}
        </section>

        <section class="mt-8 rounded-lg border border-slate-200 bg-white p-5">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Préférences</h2>

            <form action="{{ path('app_profile_preferences') }}" method="post" class="mt-4 space-y-4 text-sm">
                <div>
                    <label class="block text-slate-700" for="avatar_source">Source d'avatar préférée</label>
                    <select name="avatar_source" id="avatar_source" class="mt-1 rounded-md border border-slate-300 px-2 py-1">
                        {% for source in avatar_sources %}
                            <option value="{{ source.value }}" {{ source == user.avatarSource ? 'selected' }}>{{ source.value }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="inline-flex items-center gap-2 text-slate-700">
                        <input type="checkbox" name="gravatar_allowed" value="1" {{ user.gravatarAllowed ? 'checked' }}>
                        Autoriser le fallback Gravatar
                    </label>
                    <p class="mt-1 text-xs text-slate-500">
                        ⚠ Cela envoie le hash SHA-256 de votre e-mail à gravatar.com lors du chargement de l'avatar.
                    </p>
                </div>

                <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">
                    Enregistrer les préférences
                </button>
            </form>
        </section>
    </div>
{% endblock %}
