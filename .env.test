# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Le client OIDC drenso valide `OIDC_WELL_KNOWN_URL` au moment de
# l'instanciation du service (cf. vendor/drenso/symfony-oidc-bundle/src/OidcClient.php).
# En test, on ne fait jamais vraiment d'appel OIDC (les tests fonctionnels
# passent par `$client->loginUser()` qui court-circuite l'authenticator),
# mais le service est instancié dès qu'une requête HTTP traverse le firewall.
# On fournit donc des valeurs sentinelles qui satisfont la validation
# d'URL sans pour autant pointer vers un vrai IdP.
OIDC_WELL_KNOWN_URL=https://authentik.test/.well-known/openid-configuration
OIDC_CLIENT_ID=dummy
OIDC_CLIENT_SECRET=dummy
OIDC_ADMIN_GROUP=mairie-admins
OIDC_REQUIRED_GROUPS=
OIDC_SCOPES='openid email profile groups'
