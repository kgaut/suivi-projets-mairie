.env.*.local
docker-compose.yml
docker-compose.override.yml

# Dépendances et caches (régénérés dans l'image)
vendor/
node_modules/
var/
public/build/
public/bundles/

# Outillage qualité (pas nécessaire à l'exécution)
phpstan.neon.dist
phpstan.neon
phpunit.dist.xml
phpunit.xml
.php-cs-fixer.dist.php
.php-cs-fixer.cache
.twig-cs-fixer.dist.php
rector.php
